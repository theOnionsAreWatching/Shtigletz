<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Local contact photos are the ONLY image source the app ever uses. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- New-mail notifications (optional feature, off by default). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Lets the in-app update check hand a downloaded APK to the installer. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".DMailApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.DMail"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".LauncherActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.AccountsActivity" android:exported="false" />
        <activity android:name=".ui.SetupActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.MessageListActivity" android:exported="false" />
        <activity android:name=".ui.ReadActivity" android:exported="false" />
        <activity android:name=".ui.ComposeActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.SettingsActivity" android:exported="false" />
        <activity android:name=".ui.SoftKeyLearnActivity" android:exported="false" />
        <activity android:name=".ui.KeyInfoActivity" android:exported="false" />

        <!-- Shares files we explicitly grant: update APKs (all flavors) and
             attachments (Plus/Pro/Max). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
