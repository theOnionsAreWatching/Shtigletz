<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Local contact photos are the ONLY image source the app ever uses. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:name=".DMailApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.DMail"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".LauncherActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.AccountsActivity" android:exported="false" />
        <activity android:name=".ui.SetupActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.MessageListActivity" android:exported="false" />
        <activity android:name=".ui.ReadActivity" android:exported="false" />
        <activity android:name=".ui.ComposeActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.SettingsActivity" android:exported="false" />
    </application>
</manifest>
