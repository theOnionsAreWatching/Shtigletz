<?xml version="1.0" encoding="utf-8"?>
<!--
    Device soft-key profiles.

    model = exact android.os.Build.MODEL of the device (case-insensitive).
            (Settings app usually shows it under About phone > Model.)
    left / right = Android keyCode integers sent by the physical soft keys.

    When "Soft keys" is set to Automatic (the default), the feature turns on
    ONLY for devices listed here. To add a device, have its owner use
    Settings > Soft keys > Custom once, then Settings > "Soft-key report for
    this device" produces a ready-to-paste profile line.
-->
<profiles>
    <!-- Schock Classic -->
    <profile model="SC3218" left="1" right="2" />
    <!-- Summit Boost Flip -->
    <profile model="SL006D" left="1" right="2" />
</profiles>
