<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView android:id="@+id/readFrom"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp"
        android:textStyle="bold" android:textSize="14sp"
        android:singleLine="true" android:ellipsize="end" />

    <TextView android:id="@+id/readSubject"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:textSize="13sp" android:maxLines="2" android:ellipsize="end" />

    <TextView android:id="@+id/readMeta"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingBottom="2dp"
        android:textSize="11sp" android:alpha="0.7" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/replyButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/read_reply" />
        <Button android:id="@+id/forwardButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/read_forward" />
        <Button android:id="@+id/deleteButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/read_delete" />
        <Button android:id="@+id/prevButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/read_prev" />
        <Button android:id="@+id/nextButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/read_next" />
    </LinearLayout>

    <!-- Reading position: fills as you scroll down the message. -->
    <ProgressBar android:id="@+id/readProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100" android:progress="0" />

    <io.github.theonionsarewatching.shtigletz.ui.SafeWebView
        android:id="@+id/bodyView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
