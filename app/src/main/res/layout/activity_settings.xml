<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:paddingBottom="10dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_theme" android:textStyle="bold" />
        <Spinner android:id="@+id/themeSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_text_size" android:textStyle="bold" />
        <Spinner android:id="@+id/textSizeSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_read_bg" android:textStyle="bold" />
        <Spinner android:id="@+id/readBgSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_read_font" android:textStyle="bold" />
        <Spinner android:id="@+id/readFontSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_sort" android:textStyle="bold" />
        <Spinner android:id="@+id/sortSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView android:id="@+id/viewModeLabel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp" android:visibility="gone"
            android:text="@string/settings_view_mode" android:textStyle="bold" />
        <Spinner android:id="@+id/viewModeSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" android:visibility="gone" />

        <TextView android:id="@+id/imagesAutoLabel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp" android:visibility="gone"
            android:text="@string/settings_images_auto" android:textStyle="bold" />
        <Spinner android:id="@+id/imagesAutoSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" android:visibility="gone" />
        <Button android:id="@+id/resetSendersButton" style="@style/DMail.Button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:visibility="gone"
            android:text="@string/settings_reset_senders" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_page_size" android:textStyle="bold" />
        <Spinner android:id="@+id/pageSizeSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_auto_refresh" android:textStyle="bold" />
        <Spinner android:id="@+id/autoRefreshSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_links" android:textStyle="bold" />
        <Spinner android:id="@+id/linksSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_tap_contacts" android:textStyle="bold" />
        <Spinner android:id="@+id/tapContactsSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_notifications" android:textStyle="bold" />
        <Spinner android:id="@+id/notifySpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_notify_content" android:textStyle="bold" />
        <Spinner android:id="@+id/notifyContentSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_softkeys" android:textStyle="bold" />
        <Spinner android:id="@+id/softkeySpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/settings_softkeys_note"
            android:textSize="11sp" android:alpha="0.7" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_prefetch" android:textStyle="bold" />
        <Spinner android:id="@+id/prefetchSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="18dp"
            android:text="@string/settings_about" android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/about_url"
            android:textSize="13sp" android:alpha="0.8" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/about_license"
            android:textSize="11sp" android:alpha="0.6"
            android:paddingTop="4dp" android:paddingBottom="8dp" />

        <TextView android:id="@+id/versionText"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:alpha="0.8" />
        <Button android:id="@+id/updateButton" style="@style/DMail.Button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/settings_check_updates" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:text="@string/settings_delete_update" android:textStyle="bold" />
        <Spinner android:id="@+id/deleteUpdateSpinner"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:focusable="true" android:background="@drawable/focus_bg"
            android:minHeight="48dp" />

        <Button android:id="@+id/keyInfoButton" style="@style/DMail.Button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="@string/keyinfo_open" />
        <TextView android:id="@+id/keyInfoNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/keyinfo_open_note"
            android:textSize="11sp" android:alpha="0.6"
            android:visibility="gone"
            android:paddingTop="4dp" android:paddingBottom="12dp" />
    </LinearLayout>
</ScrollView>
