<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView android:id="@+id/listTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp"
        android:textSize="14sp" android:textStyle="bold"
        android:singleLine="true" android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/composeButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/list_compose" />
        <Button android:id="@+id/refreshButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/list_refresh" />
        <Button android:id="@+id/foldersButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/list_folders" />
        <Button android:id="@+id/moreButton" style="@style/DMail.BarButton"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/list_more" />
    </LinearLayout>

    <TextView android:id="@+id/listStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="4dp" android:paddingBottom="4dp"
        android:textSize="12sp" android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messageList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <Button android:id="@+id/loadOlderButton" style="@style/DMail.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/list_load_older"
        android:visibility="gone" />
</LinearLayout>
