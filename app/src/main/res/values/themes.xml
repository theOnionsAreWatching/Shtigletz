<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material 3, day/night, and NO action bar — screens use their own compact headers. -->
    <style name="Theme.DMail" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
    </style>

    <!-- Compact text button for button bars on small screens. The stroke
         lights up when dpad-focused, so focus is always visible. -->
    <style name="DMail.BarButton" parent="Widget.Material3.Button.TextButton">
        <item name="strokeColor">@color/focus_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:insetTop">2dp</item>
        <item name="android:insetBottom">2dp</item>
    </style>

    <!-- Tonal button for standalone actions, same dpad focus stroke. -->
    <style name="DMail.Button" parent="Widget.Material3.Button.TonalButton">
        <item name="strokeColor">@color/focus_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:insetTop">3dp</item>
        <item name="android:insetBottom">3dp</item>
    </style>
</resources>
